   Flag = "planetLoopToggle",
   Callback = function(Value) planetLoop = Value end,
})

Tab:CreateToggle({
   Name = "Observatorium",
   CurrentValue = false,
   Flag = "observatoriumLoopToggle",
   Callback = function(Value) observatoriumLoop = Value end,
})

local remote = game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("GenericFunction")

local function fireRemote(identifier, field, quantity)
    remote:InvokeServer({ id = "cut", identifier = identifier, quantity = quantity, field = field })
end

task.spawn(function()
    while true do
        if mainLoop then fireRemote("pw8", "main", 1000) end
        task.wait(0.01)
    end
end)

