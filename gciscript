local TabMain = Window:CreateTab("Main", 4483362458) -- Title, Image
local TabMisc = Window:CreateTab("Misc", 4483362458)
local TabTeleports = Window:CreateTab("Teleports", 4483362458)

local loopThread = nil -- This will store our running loop

local Toggle = TabMain:CreateToggle({
    Name = "Infinite Collider Size",
    CurrentValue = false,
    Flag = "InfiniteColliderToggle",
    Callback = function(Value)
        -- Cancel any existing loop
        if loopThread then
            task.cancel(loopThread)
            loopThread = nil
        end

        -- Only start new loop if toggled ON
        if Value then
            loopThread = task.spawn(function()
                local GrassCollider = workspace:FindFirstChild("GrassCollider")
                if GrassCollider then
                    GrassCollider = GrassCollider:FindFirstChild("GrassCollider") or GrassCollider
                end

                while Value do  -- Will stop when Value becomes false
                    if GrassCollider and GrassCollider:IsA("BasePart") then
                        GrassCollider.Size = Vector3.new(20000, 100, 20000)
                    else
                        warn("GrassCollider missing or invalid!")
                    end
                    task.wait(0.05)
                end
            end)
        end
    end
})

