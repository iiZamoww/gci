local Tab = Window:CreateTab("Cut", 4483362458)

local mainLoop = false
local antiLoop = false
local unLoop = false
local planetLoop = false
local observatoriumLoop = false

Tab:CreateToggle({
   Name = "Main",
   CurrentValue = false,
   Flag = "mainLoopToggle",
   Callback = function(Value) mainLoop = Value end,
})

Tab:CreateToggle({
   Name = "Anti",
   CurrentValue = false,
   Flag = "antiLoopToggle",
   Callback = function(Value) antiLoop = Value end,
})

Tab:CreateToggle({
   Name = "Unnatural",
   CurrentValue = false,
   Flag = "unLoopToggle",
   Callback = function(Value) unLoop = Value end,
})

Tab:CreateToggle({
   Name = "Planet",
